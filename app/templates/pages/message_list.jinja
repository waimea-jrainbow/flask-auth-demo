{#=====================================================
  Creature List page
=====================================================#}

{% extends 'pages/base.jinja' %}


{% block content %}

    <h2>Message board</h2>

    <section id="board_messages">

        {% for message in board_messages %}

            <div class="board_message">
                <h3 class="message_title">{{ message.title }}</h3>
                <h6 class="message_author">posted by {{ message.username }}</h6>
                <p class="message_body">{{ message.body }}</p>
                {% if session.get("user") and (message.user_id == session["user"]["id"] or session["user"]["isAdmin"] == 1) %}
                    <span><a class="button" href="/message/{{ message.id }}/edit_message">🖊️ Edit</a></span>
                    <span><a class="button" href="/message/{{ message.id }}/delete" onclick="return confirm('Really delete?')">🗑 Delete</a></span>
                {% endif %}

                <details>
                    <summary>Replies</summary>
                    <form method="post" action="/message/{{ message.id }}/post_reply">
    
                        <label>
                            Reply:
                            <input type = "text" name = "body" required>
                        </label>
                        <button>Submit</button>
                    </form>
                    <div hx-get="/message/{{ message.id }}/replies" hx-trigger="load" hx-target="this" hx-swap="innerHTML"> </div>
                </details>

            </div>

        {% else %}

            <p>No Messages!</p>

        {% endfor %}

    </section>

{% endblock %}

