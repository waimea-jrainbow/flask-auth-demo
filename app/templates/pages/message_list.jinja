{#=====================================================
  Creature List page
=====================================================#}

{% extends 'pages/base.jinja' %}


{% block content %}

    <h2>Message board</h2>

    <section id="board_messages">

        {% for message in board_messages %}

            <div class="board_message">
                <h3 class="message_title">{{ message.title }}</h3>
                <h6 class="message_author">posted by {{ message.username }}</h6>
                <p class="message_body">{{ message.body }}</p>
                {% if session.get("user") and (message.user_id == session["user"]["id"] or session["user"]["isAdmin"] == 1) %}
                    <span><button class="button" href="/message/{{ message.id }}/edit_message">🖊️ Edit</button></span>
                    <span><button class="button" href="/message/{{ message.id }}/delete" onclick="return confirm('Really delete?')">🗑 Delete</button></span>
                {% endif %}

                <details>
                    <summary>Replies</summary>
                    {% for reply in replies_by_message.get(message.id, []) %}
                        <div class="replies"> 
                            <h6 class="reply_author">posted by {{ reply.username }}</h6>
                            <p class="reply_body">{{ reply.body }}</p>
                            {# {% if session.get("user") and (reply.user_id == session["user"]["id"] or session["user"]["isAdmin"] == 1) %}
                                <span><button class="button" href="/message/{{ message.id }}/edit_message">🖊️ Edit</button></span>
                                <span><button class="button" href="/message/{{ message.id }}/delete" onclick="return confirm('Really delete?')">🗑 Delete</button></span>
                            {% endif %} #}
                        </div> 
                    {% else %} <p>No Replies!</p>
                    {% endfor %}
                </details>

            </div>

        {% else %}

            <p>No Messages!</p>

        {% endfor %}

    </section>

{% endblock %}

